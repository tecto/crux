{
  "model": "ollama/crux-think",
  "small_model": "ollama/qwen3:8b",
  "provider": {
    "ollama": {
      "options": {
        "endpoint": "http://localhost:11434"
      }
    }
  },
  "lsp": {
    "python": {
      "command": "pyright",
      "args": ["--outputjson"]
    },
    "elixir": {
      "command": "elixir-ls",
      "alternative": "next-ls"
    }
  },
  "timeout": 600000,
  "permission": {
    "edit": "ask",
    "bash": "ask"
  },
  "compaction": {
    "enabled": true
  }
}
