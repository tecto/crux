{
  "name": "crux",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:bats": "bats tests/*.bats",
    "test:py": ".venv/bin/pytest tests/ -v --tb=short",
    "test:py:cov": ".venv/bin/pytest tests/ -v --tb=short --cov=scripts/lib --cov-report=term-missing --cov-fail-under=100",
    "test:all": "npm run test:bats && npm run test && npm run test:py"
  },
  "devDependencies": {
    "zod": "^3.22.0"
  }
}
