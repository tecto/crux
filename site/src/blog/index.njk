---
layout: base.njk
title: blog - crux
description: build-in-public log from building crux
---

<h1>build log</h1>

<ul class="post-list blog-index">
{% for post in collections.post | reverse %}
  <li class="post-item">
    <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
    <time>{{ post.date | readableDate }}</time>
    {% if post.data.summary %}
    <p>{{ post.data.summary }}</p>
    {% endif %}
  </li>
{% else %}
  <li>no posts yet.</li>
{% endfor %}
</ul>
